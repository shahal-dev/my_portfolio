# Root-level safety net — each subproject (frontend/, cms/) also has its own
# .gitignore; this catches anything in either regardless of location.
**/node_modules
**/.next/
**/out/
**/dist/
**/build/
**/.env
**/.env.local
**/.env.*.local
.DS_Store
.idea/
.vscode/

# Generated at deploy time by init-tls.sh (contains the VM's derived
# sslip.io hostname) — not committed, see nginx/available/ for the source
# templates.
nginx/conf.d/*.conf
